classDiagram
    %% PawPal+ final class diagram — synced with pawpal_system.py

    class Owner {
        +str name
        +int minutes_available
        +str preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +remove_pet(pet) None
        +get_all_tasks() list~Task~
        +get_pending_tasks() list~Task~
    }

    class Pet {
        +str name
        +str breed
        +str gender
        +float weight
        +float height
        +int age
        +str health_conditions
        +list~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
        +pending_tasks() list~Task~
    }

    class Task {
        +str description
        +int duration_minutes
        +str priority
        +str frequency
        +str start_time
        +date due_date
        +bool completed
        +Pet pet
        +is_high_priority() bool
        +priority_rank() int
        +is_recurring() bool
        +next_occurrence() Task|None
        +mark_complete() Task|None
        +mark_incomplete() None
    }

    class Scheduler {
        +Owner owner
        +sort_by_priority(tasks) list~Task~
        +sort_by_time(tasks) list~Task~
        +filter_by_status(completed) list~Task~
        +filter_by_pet(pet_name) list~Task~
        +detect_conflicts(tasks) list~str~
        +generate_plan() list~Task~
        +explain_plan() str
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" <--> "0..*" Task : has / belongs to
    Task ..> Task : spawns next occurrence
    Scheduler "1" --> "1" Owner : reads tasks from
