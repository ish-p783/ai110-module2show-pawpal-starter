classDiagram
    %% PawPal+ class diagram
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +int minutes_available
        +str preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +remove_pet(pet) None
        +get_all_tasks() list~Task~
        +get_pending_tasks() list~Task~
    }

    class Pet {
        +str name
        +str breed
        +str gender
        +float weight
        +float height
        +int age
        +str health_conditions
        +list~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
        +pending_tasks() list~Task~
    }

    class Task {
        +str description
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +Pet pet
        +is_high_priority() bool
        +priority_rank() int
        +mark_complete() None
        +mark_incomplete() None
    }

    class Scheduler {
        +Owner owner
        +sort_by_priority(tasks) list~Task~
        +generate_plan() list~Task~
        +explain_plan() str
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "1" Owner : reads tasks from
